    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ===== USERS (perfil + rol) =====
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      // admin puede crear perfiles de otros; usuario puede crear el suyo (si habilitas self-onboarding)
      allow create: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow update, delete: if isAdmin();
    }

    // ===== PRODUCTOS =====
    match /producto/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== EMPLEADOS (listado/metadata) =====
    match /empleado/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== ASISTENCIA =====
    // Este proyecto deja Asistencia como ADMIN ONLY (escaneo QR + marcación).
    match /registroempleado/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ===== MOVIMIENTOS =====
    match /movimientos/{id} {
      allow read: if signedIn() && (isAdmin() || resource.data.creadoPorUid == request.auth.uid);
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /movimiento/{id} {
      allow read: if signedIn() && (isAdmin() || resource.data.creadoPorUid == request.auth.uid);
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // ===== INVENTARIO DIARIO =====
    match /inventarios_diarios/{fechaKey} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /items/{productoId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin();
      }
    }

